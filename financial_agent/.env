# ============================================================
# 財務 AI 助手 設定檔（改這裡就好，不用每次在 PowerShell key 變數）
# 規則：KEY=VALUE 一行一個；# 開頭整行是註解。真實環境變數會「優先」於這裡。
# ============================================================

# ── 多語言關鍵：日文/中文檔翻成英文再入庫（MiniLM 對日文弱，翻英大幅改善檢索）──
FA_NORMALIZE_LANG=en

# ── 確定性解析管線：固定英文指標查詢、不讓模型亂搜（避免日文檔狂搜十幾次）──
FA_DETERMINISTIC_GATHER=1
FA_GATHER_WORKERS=3

# ── 全頁 vision OCR：每頁都用 glm-ocr 完整辨識（財報複雜表格較穩；較花成本/時間）──
# 實測 find_tables 抽原生表格不穩、易漏數據，全頁 OCR 效果較好，故預設關閉懶人 OCR。
# 想省成本可改 FA_LAZY_OCR=1（有文字層直接抽、只有掃描頁才 vision）。
FA_LAZY_OCR=0

# ── 模型角色（你目前用 gemma4；想一鍵全設同一顆改用 FA_MODEL）──
#FA_MODEL=gemma4:31b
FA_PLANNER=qwen3.6:35b-a3b
FA_EXECUTOR=qwen3.6:35b-a3b
FA_SYNTHESIZER=gemma4:31b
FA_CODER=qwen3.6:27b
FA_CHAT=gemma4:31b
FA_VISION=glm-ocr

# ── 成本/效能微調（要動再取消註解）──
#FA_MAX_EVIDENCE_CHARS=16000
#FA_REQUEST_TIMEOUT=240

# ── Ollama 連線（預設本機）──
#OLLAMA_BASE_URL=http://localhost:11434/v1
