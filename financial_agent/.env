# ============================================================
# 財務 AI 助手 設定檔（改這裡就好，不用每次在 PowerShell key 變數）
# 規則：KEY=VALUE，一行一個；# 開頭整行是註解。
# 真實環境變數會「優先」於這裡（臨時覆寫用）。
# ============================================================

# ── 本機模型路徑 ──
# 裝好 bge 模型後，把下面兩行取消註解(去掉#)並填你的路徑。
# 不填的話：embedding 退回原本 MiniLM、reranker 關閉。
#FA_EMBED_MODEL=D:\你的路徑\bge-m3
#FA_RERANK_MODEL=D:\你的路徑\bge-reranker-large

# ── 生產級多語言 RAG ──
# 混合檢索（dense + BM25 + RRF）
FA_HYBRID_RETRIEVAL=1
# query rewrite + HyDE + 多子查詢融合 + rerank
FA_RAG_V2=1
# 留空＝關閉英文正規化（bge-m3 跨語言，不必翻英）
FA_NORMALIZE_LANG=

# ── 確定性解析管線（檔案分析不再讓 LLM 逐步決策，較快較穩）──
FA_DETERMINISTIC_GATHER=1
FA_GATHER_WORKERS=3

# ── 模型角色（你目前用 gemma4；想一鍵全設同一顆改用 FA_MODEL）──
#FA_MODEL=gemma4:31b
FA_PLANNER=gemma4:31b
FA_EXECUTOR=gemma4:31b
FA_SYNTHESIZER=gemma4:31b
FA_CODER=gemma4:31b
FA_CHAT=gemma4:31b
FA_VISION=glm-ocr

# ── 成本/效能微調（通常不用動；要開再取消註解）──
#FA_RAG_RERANK_TOPN=20
#FA_RAG_MAX_SUBQ=3
#FA_MAX_EVIDENCE_CHARS=16000
#FA_REQUEST_TIMEOUT=240

# ── Ollama 連線（預設本機）──
#OLLAMA_BASE_URL=http://localhost:11434/v1
